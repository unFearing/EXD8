{
  "name": "exd8-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:ts",
    "test": "vitest run",
    "validate:foam-mechs": "npm run build:ts && node dist/scripts/validateFoamMechs.js",
    "sync:foam-to-cosmos": "node dist/scripts/syncFoamToCosmos.js",
    "sync:cosmos-to-foam": "node dist/scripts/syncCosmosToFoam.js",
    "sync:repository-index": "node dist/scripts/generateFoamRepositoryIndex.js",
    "sync:all": "npm run build:ts && npm run sync:foam-to-cosmos && npm run sync:repository-index && npm run sync:cosmos-to-foam",
    "watch:sync": "npm run build:ts && node dist/scripts/watchSync.js",
    "export:mechs-csv": "npm run build:ts && node dist/scripts/exportMechsToCsv.js",
    "migrate:mechs-config": "npm run build:ts && node dist/scripts/migrateMechsToConfig.js",
    "test:parse-links": "npm run build:ts && node dist/scripts/testParseBuildLinks.js",
    "migrate:strip-codename": "npm run build:ts && node dist/scripts/stripCodenameFromCosmos.js",
    "migrate:prune-stale-mechs": "npm run build:ts && node dist/scripts/pruneStaleMechDocs.js",
    "prestart": "npm run build",
    "start": "func start"
  },
  "dependencies": {
    "@azure/cosmos": "^4.3.0",
    "@azure/functions": "^4.7.3",
    "typescript": "^5.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "vitest": "^2.1.8"
  }
}
